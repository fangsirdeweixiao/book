# Webnovel-Writer 环境配置
# 复制此文件为 .env 并填入实际值

# ==================== RAG配置 ====================
# 使用Jina AI（嵌入+重排一体化）
EMBED_BASE_URL=https://api.jina.ai/v1
EMBED_MODEL=jina-embeddings-v3
EMBED_API_KEY=jina_4050440d9afe47c19a6ade25813412c4_-u2Z_d57oEihzCTGyUoK0dONcmz

# 重排模型（Jina）
RERANK_BASE_URL=https://api.jina.ai/v1
RERANK_MODEL=jina-reranker-v3
RERANK_API_KEY=jina_4050440d9afe47c19a6ade25813412c4_-u2Z_d57oEihzCTGyUoK0dONcmz

# ==================== 项目配置 ====================
# 项目名称
PROJECT_NAME=智脑纪元：暗子降临

# 项目简称（用于目录名）
PROJECT_SLUG=santi-waipian

# 目标规模
TARGET_WORDS=300000
TARGET_CHAPTERS=90

# 创作模式：novel（长篇小说）/ webnovel（网文连载）
CREATION_MODE=novel
