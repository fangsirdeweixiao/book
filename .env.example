# Webnovel-Writer 环境配置
# 复制此文件为 .env 并填入实际值

# ==================== RAG配置 ====================
# 向量嵌入模型（用于语义检索）
EMBED_BASE_URL=https://api-inference.modelscope.cn/v1
EMBED_MODEL=Qwen/Qwen3-Embedding-8B
EMBED_API_KEY=your_embed_api_key_here

# 重排模型（用于优化检索结果）
RERANK_BASE_URL=https://api.jina.ai/v1
RERANK_MODEL=jina-reranker-v3
RERANK_API_KEY=your_rerank_api_key_here

# ==================== 项目配置 ====================
# 项目名称
PROJECT_NAME=智脑纪元：暗子降临

# 项目简称（用于目录名）
PROJECT_SLUG=santi-waipian

# 目标规模
TARGET_WORDS=300000
TARGET_CHAPTERS=90

# 创作模式：novel（长篇小说）/ webnovel（网文连载）
CREATION_MODE=novel
